<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="UniVerse - Secure, hyper-local social marketplace for Nigerian students">
  <meta name="theme-color" content="#1a1a2e">
  
  <!-- PWA Meta Tags -->
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="UniVerse">
  
  <title>UniVerse - Your Campus Universe</title>
  
  <!-- Styles -->
  <link rel="stylesheet" href="/css/main.css">
  <link rel="stylesheet" href="/css/glassmorphism.css">
  
  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/logo.png">
</head>
<body>
  <!-- Main Container -->
  <div class="app-container">
    
    <!-- Header -->
    <header class="glass-header">
      <div class="header-content">
        <div class="logo">
          <span class="logo-icon">🌌</span>
          <h1>UniVerse</h1>
        </div>
        
        <div class="header-actions">
          <button class="icon-btn glass-btn" id="notificationBtn">
            <span class="icon">🔔</span>
            <span class="badge">3</span>
          </button>
          <button class="icon-btn glass-btn" id="profileBtn">
            <span class="icon">👤</span>
          </button>
        </div>
      </div>
    </header>

    <!-- Main Content Area -->
    <main class="main-content" id="mainContent">
      
      <!-- Welcome Section -->
      <section class="welcome-section">
        <div class="glass-card hero-card">
          <div class="hero-content">
            <h2 class="hero-title">Welcome to UniVerse</h2>
            <p class="hero-subtitle">Your Campus Operating System</p>
            <p class="hero-description">
              Earn through gigs, learn from peers, and connect with your tribe. 
              Secured by the Marshlytes Protocol.
            </p>
            
            <div class="hero-stats">
              <div class="stat-item glass-card-sm">
                <span class="stat-number">5000+</span>
                <span class="stat-label">Students</span>
              </div>
              <div class="stat-item glass-card-sm">
                <span class="stat-number">1000+</span>
                <span class="stat-label">Gigs</span>
              </div>
              <div class="stat-item glass-card-sm">
                <span class="stat-number">50+</span>
                <span class="stat-label">Tribes</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Features Grid -->
      <section class="features-section">
        <h3 class="section-title">Explore the Universe</h3>
        
        <div class="features-grid">
          <!-- EARN Feature -->
          <a href="/gigs.html" class="feature-card glass-card">
            <div class="feature-icon">💼</div>
            <h4 class="feature-title">EARN</h4>
            <p class="feature-description">
              Find digital and physical gigs. Every payment secured by escrow.
            </p>
            <div class="feature-badge marshlyte-badge">
              <span class="shield-icon">🛡️</span>
              <span>Marshlyte Protected</span>
            </div>
          </a>

          <!-- LEARN Feature -->
          <a href="/library.html" class="feature-card glass-card">
            <div class="feature-icon">📚</div>
            <h4 class="feature-title">LEARN</h4>
            <p class="feature-description">
              Get tutoring, share resources, and ace your academics together.
            </p>
          </a>

          <!-- CONNECT Feature -->
          <a href="/tribes.html" class="feature-card glass-card">
            <div class="feature-icon">🌟</div>
            <h4 class="feature-title">CONNECT</h4>
            <p class="feature-description">
              Join tribes based on interests and location. Your campus family.
            </p>
          </a>
        </div>
      </section>

      <!-- Recent Activity Section -->
      <section class="activity-section">
        <h3 class="section-title">Recent Activity</h3>
        
        <div class="activity-list">
          <div class="activity-item glass-card-sm">
            <div class="activity-icon">💰</div>
            <div class="activity-content">
              <p class="activity-title">New Gig Posted</p>
              <p class="activity-description">Web design needed for student startup</p>
              <span class="activity-time">5 mins ago</span>
            </div>
          </div>

          <div class="activity-item glass-card-sm">
            <div class="activity-icon">🎓</div>
            <div class="activity-content">
              <p class="activity-title">Study Group Started</p>
              <p class="activity-description">CSC 301 Algorithms Study Session</p>
              <span class="activity-time">15 mins ago</span>
            </div>
          </div>

          <div class="activity-item glass-card-sm">
            <div class="activity-icon">🎨</div>
            <div class="activity-content">
              <p class="activity-title">New Tribe Created</p>
              <p class="activity-description">Digital Artists Collective</p>
              <span class="activity-time">1 hour ago</span>
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- Floating Navigation Dock -->
    <nav class="nav-dock glass-dock">
      <a href="/" class="nav-item active">
        <span class="nav-icon">🏠</span>
        <span class="nav-label">Home</span>
      </a>
      <a href="/tribes.html" class="nav-item">
        <span class="nav-icon">🌟</span>
        <span class="nav-label">Tribes</span>
      </a>
      <a href="/gigs.html" class="nav-item">
        <span class="nav-icon">💼</span>
        <span class="nav-label">Gigs</span>
      </a>
      <a href="/library.html" class="nav-item">
        <span class="nav-icon">📚</span>
        <span class="nav-label">Library</span>
      </a>
      <a href="/profile.html" class="nav-item">
        <span class="nav-icon">👤</span>
        <span class="nav-label">Profile</span>
      </a>
    </nav>

    <!-- Floating Action Button (for creating posts) -->
    <button class="fab glass-fab" id="createBtn">
      <span class="fab-icon">➕</span>
    </button>

  </div>

  <!-- Scripts -->
  <script src="/js/main.js"></script>
  <script src="/js/pwa.js"></script>
</body>
</html>
